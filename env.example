# Superwhisper Lab — environment variable overrides
#
# Copy this file to .env and uncomment/edit paths for your machine.
# All variables are optional — the scripts fall back to standard macOS
# Superwhisper paths under ~/Documents/superwhisper/ when not set.

# Path to Superwhisper's recordings folder (contains numbered subdirs with meta.json + output.wav)
# SUPERWHISPER_RECORDINGS_DIR=~/Documents/superwhisper/recordings

# Root directory where timestamped export bundles are written
# SUPERWHISPER_EXPORT_ROOT=~/Documents/superwhisper_exports

# Path to Superwhisper's live modes directory
# SUPERWHISPER_MODES_DIR=~/Documents/superwhisper/modes

# Path to Superwhisper's settings.json
# SUPERWHISPER_SETTINGS_PATH=~/Documents/superwhisper/settings/settings.json
